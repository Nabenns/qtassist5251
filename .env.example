# ==============================================
# DISCORD BOT CONFIGURATION
# ==============================================
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_server_guild_id_here

# ==============================================
# POSTGRESQL DATABASE CONFIGURATION
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qtassist_bot
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ==============================================
# GOOGLE SHEETS API CONFIGURATION
# ==============================================
# Setup guide: https://console.cloud.google.com/
# 1. Create project & enable Google Sheets API
# 2. Create Service Account & download JSON credentials
# 3. Extract client_email and private_key from JSON
# 4. Create Google Spreadsheet and share with service account email (Editor access)
# 5. Copy spreadsheet ID from URL (between /d/ and /edit)

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ==============================================
# DISCORD CHANNEL IDS
# ==============================================
# Right-click channel in Discord > Copy Channel ID (Developer Mode must be enabled)

# Channel untuk admin review payment proofs
PAYMENT_REVIEW_CHANNEL_ID=

# Channel untuk user upload payment proofs (bot will auto-create temporary threads)
PAYMENT_UPLOAD_CHANNEL_ID=

# Channel untuk moderation logs (optional)
MOD_LOG_CHANNEL_ID=

# Channel untuk temporary role expiry notifications (optional)
TEMP_ROLE_NOTIFICATION_CHANNEL_ID=

# ==============================================
# BANK TRANSFER CONFIGURATION (MANUAL PAYMENT)
# ==============================================
# Format untuk multiple rekening: pisahkan dengan | (pipe)
# Semua array harus punya jumlah item yang sama
#
# Contoh untuk 3 rekening:
# BANK_NAMES=BCA|Mandiri|SeaBank
# ACCOUNT_NUMBERS=1234567890|9876543210|1112223334
# ACCOUNT_HOLDERS=QTrades Main|QTrades Backup|QTrades Official

BANK_NAMES=BCA|Mandiri
ACCOUNT_NUMBERS=1234567890|9876543210
ACCOUNT_HOLDERS=QTrades Official|QTrades Backup

# ==============================================
# BRANDING (OPTIONAL)
# ==============================================
# Logo URL untuk Discord embeds (optional)
QTRADES_LOGO_URL=https://your-cdn.com/logo.png

# ==============================================
# ENVIRONMENT
# ==============================================
NODE_ENV=development

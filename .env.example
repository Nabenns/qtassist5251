# ==============================================
# DISCORD BOT CONFIGURATION
# ==============================================
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_GUILD_ID=your_server_guild_id_here

# Wajib untuk login dashboard pakai Discord OAuth.
# Set ke base URL dashboard kamu, contoh: https://qtrades.bensserver.cloud
# Bot bakal pakai ini untuk build redirect URI:
#   ${DASHBOARD_BASE_URL}/api/auth/discord/callback
# Kamu HARUS daftar URL yang sama persis di Discord Developer Portal:
#   Application -> OAuth2 -> Redirects -> Add Redirect
DASHBOARD_BASE_URL=http://localhost:3000

# ==============================================
# POSTGRESQL DATABASE CONFIGURATION
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qtassist_bot
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ==============================================
# GOOGLE SHEETS API CONFIGURATION
# ==============================================
# Setup guide: https://console.cloud.google.com/
# 1. Create project & enable Google Sheets API
# 2. Create Service Account & download JSON credentials
# 3. Extract client_email and private_key from JSON
# 4. Create Google Spreadsheet and share with service account email (Editor access)
# 5. Copy spreadsheet ID from URL (between /d/ and /edit)

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ==============================================
# DISCORD CHANNEL IDS
# ==============================================
# Right-click channel in Discord > Copy Channel ID (Developer Mode must be enabled)

# Channel untuk admin review payment proofs
PAYMENT_REVIEW_CHANNEL_ID=

# Channel untuk user upload payment proofs (bot will auto-create temporary threads)
PAYMENT_UPLOAD_CHANNEL_ID=

# Channel untuk moderation logs (optional)
MOD_LOG_CHANNEL_ID=

# Channel untuk temporary role expiry notifications (optional)
TEMP_ROLE_NOTIFICATION_CHANNEL_ID=

# ==============================================
# BANK TRANSFER CONFIGURATION (MANUAL PAYMENT)
# ==============================================
# Format untuk multiple rekening: pisahkan dengan | (pipe)
# Semua array harus punya jumlah item yang sama
#
# Contoh untuk 3 rekening:
# BANK_NAMES=BCA|Mandiri|SeaBank
# ACCOUNT_NUMBERS=1234567890|9876543210|1112223334
# ACCOUNT_HOLDERS=QTrades Main|QTrades Backup|QTrades Official

BANK_NAMES=BCA|Mandiri
ACCOUNT_NUMBERS=1234567890|9876543210
ACCOUNT_HOLDERS=QTrades Official|QTrades Backup

# ==============================================
# BRANDING (OPTIONAL)
# ==============================================
# Logo URL untuk Discord embeds (optional)
QTRADES_LOGO_URL=https://your-cdn.com/logo.png

# ==============================================
# ADMIN WEB DASHBOARD
# ==============================================
# Login dashboard sekarang FULL Discord OAuth â€” username/password lama
# sudah ditiadakan. User Discord yang carry role admin (lihat tabel
# admin_roles di database, dikelola via dashboard) bakal diarahkan ke
# dashboard admin penuh; user lain otomatis diarahkan ke /daftar-ib.

# Port untuk Express admin dashboard (default 3000). nginx akan reverse-proxy
# domain kamu ke port ini.
WEB_PORT=3000

# Secret untuk sign JWT session token. Minimal 32 karakter (rekomendasi 64).
# Generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Nama cookie session (optional, default: qtassist_session)
SESSION_COOKIE_NAME=qtassist_session

# ==============================================
# DATABASE BACKUP (OPTIONAL)
# ==============================================
# Folder Google Drive tempat menyimpan backup .sql.gz harian.
# CARA SETUP:
#   1. Buka https://drive.google.com â†’ klik "+ New" â†’ "Folder" â†’ beri nama
#      "QTAssist Backups" (atau nama lain).
#   2. Klik kanan folder â†’ Share â†’ tambahkan email service account
#      (sama dengan GOOGLE_SERVICE_ACCOUNT_EMAIL di atas) dengan akses
#      "Editor". Hapus checkbox "Notify people" sebelum klik Share.
#   3. Buka folder, copy ID dari URL (bagian setelah /folders/).
#      Contoh: https://drive.google.com/drive/folders/1aBcDeFgHi... â†’ ID nya `1aBcDeFgHi...`
#   4. Paste ID di bawah, save .env, restart bot.
# Kalau kosong, bot akan coba bikin folder sendiri di Drive service account
# yang biasanya gagal karena service account tidak punya storage quota.
GOOGLE_BACKUP_FOLDER_ID=

# ==============================================
# IB (INTRODUCING BROKER) INTEGRATION (OPTIONAL)
# ==============================================
# Sistem otomasi pendaftaran IB Valetax: user submit nomor akun via Discord,
# bot cek otomatis ke Valetax, kasih role kalau valid + cek volume harian.
#
# Phase 1 (sekarang): valetaxService masih pakai mock data buat test.
# Phase 2 (TODO): integrasi real ke Valetax (lihat TODO.md).
#
# VALETAX_MODE=live untuk panggil API real, atau biarkan kosong untuk mock.
VALETAX_MODE=
VALETAX_BASE_URL=

# Aktifkan log detail Valetax API call (URL, body, response preview).
# Dipakai untuk debugging field-mapping pertama kali atau diagnose 401.
# JANGAN aktifkan di production — response body bisa berisi PII partner.
VALETAX_DEBUG=

# Kunci enkripsi opsional untuk cookie Valetax. Kalau tidak diisi, bot
# pakai JWT_SECRET (di atas) sebagai sumber. Set custom kalau mau scope
# secret terpisah supaya rotasi JWT tidak invalidate cookie.
COOKIE_ENCRYPTION_KEY=

# ==============================================
# ENVIRONMENT
# ==============================================
# Set ke `production` di VPS supaya secure cookies aktif dan caching static assets jalan.
NODE_ENV=development

# ============================================================
# Louvin Payment Gateway (web shop /shop)
# ============================================================
# Set true untuk aktifkan flow Louvin di /shop. Existing Discord
# manual bank transfer ga terpengaruh.
LOUVIN_ENABLED=false

# API key dari https://louvin.dev Dashboard → Proyek → Detail Proyek
# Format: lv_<random>
LOUVIN_API_KEY=

# Random hex untuk webhook path token. Generate:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Webhook URL untuk register di Louvin Dashboard:
#   ${DASHBOARD_BASE_URL}/api/webhooks/louvin/${LOUVIN_WEBHOOK_TOKEN}
LOUVIN_WEBHOOK_TOKEN=

# Default description di Louvin transaction (visibility di Louvin Dashboard)
LOUVIN_DEFAULT_DESCRIPTION=Pembelian role QTrades

# Discord invite URL untuk user yang belum di guild
DISCORD_INVITE_URL=https://discord.gg/qtrades

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_server_guild_id_here

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qtassist_bot
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Google Sheets API Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_google_service_account_private_key_here
GOOGLE_SPREADSHEET_ID=

# Bot Configuration
MOD_LOG_CHANNEL_ID=
TEMP_ROLE_NOTIFICATION_CHANNEL_ID=
PAYMENT_REVIEW_CHANNEL_ID=
PAYMENT_UPLOAD_CHANNEL_ID=
QTRADES_LOGO_URL=

# Bank Transfer Configuration (Manual Payment)
# Format untuk multiple rekening: pisahkan dengan | (pipe)
# Contoh: BCA|Mandiri untuk 2 bank
# Contoh: 1234567890|9876543210 untuk 2 nomor rekening
BANK_NAMES=BCA|Mandiri
ACCOUNT_NUMBERS=1234567890|9876543210
ACCOUNT_HOLDERS=QTrades Official|QTrades Backup

# Legacy support (jika cuma 1 rekening, pakai ini)
# BANK_NAME=BCA
# ACCOUNT_NUMBER=1234567890
# ACCOUNT_HOLDER=QTrades Official

# Environment
NODE_ENV=development
